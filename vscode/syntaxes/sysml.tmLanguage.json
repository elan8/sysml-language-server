{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "SysML",
  "scopeName": "source.sysml",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#metadata" },
    { "include": "#keywords" },
    { "include": "#numbers" },
    { "include": "#operators" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.sysml",
          "match": "//(?!\\*).*$"
        },
        {
          "name": "comment.block.sysml",
          "begin": "/\\*",
          "end": "\\*/"
        },
        {
          "name": "comment.block.sysml",
          "begin": "//\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.single.sysml",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.sysml",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.double.sysml",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.sysml",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "metadata": {
      "patterns": [
        {
          "name": "entity.name.tag.annotation.sysml",
          "match": "@[a-zA-Z_][a-zA-Z0-9_]*(?:::[a-zA-Z_][a-zA-Z0-9_]*)*(?=\\s|\\{|;|$)"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.sysml",
          "match": "\\b(package|library|import|part|def|attribute|port|connection|interface|item|value|action|requirement|ref|alias|view|metadata|filter|connector|bind|allocate|connect|variant|abstract|occurrence|calc|constraint|exhibit|transition|accept|do|then|first|if|send|new|to|for|perform|assert|assume|require|doc|standard|expose|verify|position|satisfy|return|in|out|provides|requires|nonunique|ordered|redefines|subsets|default|istype|at|when|render|pin|connect|state|individual|flow|succession|end)\\b"
        },
        {
          "name": "keyword.other.sysml",
          "match": "\\b(private|public|true|false)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.sysml",
          "match": "-?\\d+\\.\\d+([eE][+-]?\\d+)?|-?\\d+[eE][+-]?\\d+"
        },
        {
          "name": "constant.numeric.integer.sysml",
          "match": "-?\\b\\d+\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.sysml",
          "match": ":>|:>>|::|\\.\\.|->"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.sysml",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_-]*\\b"
        }
      ]
    }
  }
}
