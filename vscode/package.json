{
  "name": "sysml-language-server",
  "displayName": "SysML Language Server",
  "publisher": "Elan8",
  "description": "LSP client for SysML v2 (KerML) via sysml-language-server",
  "version": "0.2.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/elan8/sysml-language-server.git"
  },
  "homepage": "https://github.com/elan8/sysml-language-server#readme",
  "bugs": {
    "url": "https://github.com/elan8/sysml-language-server/issues"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Linters"
  ],
  "activationEvents": [
    "onLanguage:sysml",
    "onLanguage:kerml"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "sysml",
        "aliases": [
          "SysML",
          "SysML v2"
        ],
        "extensions": [
          ".sysml"
        ],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "kerml",
        "aliases": [
          "KerML",
          "Kernel Modeling Language"
        ],
        "extensions": [
          ".kerml"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "sysml",
        "scopeName": "source.sysml",
        "path": "./syntaxes/sysml.tmLanguage.json"
      },
      {
        "language": "kerml",
        "scopeName": "source.sysml",
        "path": "./syntaxes/sysml.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "SysML Language Server",
      "properties": {
        "sysml-language-server.serverPath": {
          "type": "string",
          "default": "sysml-language-server",
          "description": "Path to the sysml-language-server binary (or 'sysml-language-server' if on PATH)."
        },
        "sysml-language-server.libraryPaths": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "Paths to SysML library roots (e.g. SysML-v2-Release clone or custom libraries). Files under these paths are indexed for hover, go-to-definition, and completion."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "vscode-test",
    "package": "vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.0",
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.4.1",
    "@vscode/vsce": "^3.2.2",
    "typescript": "~5.6.0"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.0",
    "vscode-languageserver-protocol": "^3.17.0"
  }
}
